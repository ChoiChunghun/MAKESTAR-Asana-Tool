/**
 * ============================================================
 *  Asana 태스크 자동 생성 스크립트 v11.1 (초보자 설명용 주석판)
 * ============================================================
 *
 * [이 스크립트가 하는 일]
 * 1) 구글시트에서 상품코드를 찾습니다.
 * 2) "메이크스타 특전" 영역 아래에서 포토카드 / 특전 정보를 읽어옵니다.
 * 3) 읽어온 정보를 바탕으로 Asana에
 *    - 상위 MD 태스크
 *    - 하위 포토카드 태스크
 *    - 하위 특전 태스크
 *    - 상위 업데이트 태스크
 *    - 하위 업데이트 태스크
 *    를 자동으로 생성합니다.
 *
 * [초보자용 핵심 이해 포인트]
 * - 이 코드는 "시트에서 정보 읽기" + "Asana에 태스크 만들기" 두 일을 합니다.
 * - parse... 함수들은 시트에서 데이터를 읽는 역할입니다.
 * - build... 함수들은 Asana 태스크 본문(설명)을 만드는 역할입니다.
 * - create... 함수들은 실제로 Asana에 태스크를 만드는 역할입니다.
 */


// ── 1. 설정값 영역 ─────────────────────────────────────────────
// 아래 값들은 실제 운영 환경에 맞춰 미리 세팅해 두는 값입니다.

// Asana 개인 토큰
// 주의: 실제 운영 시에는 노출되지 않도록 관리하는 것이 좋습니다.
const ASANA_TOKEN     = 'YOUR_ASANA_PERSONAL_ACCESS_TOKEN';

// 태스크를 만들 Asana 프로젝트 GID
const TESTFARM_GID    = '1213881735025332';

// 기본 담당자 GID (예: 디자인센터 담당자)
const ASSIGNEE_GID    = '1144816139914898';

// 오늘 기준 며칠 뒤를 마감일로 잡을지
const DUE_DAYS_OFFSET = 7;


// ── 2. Asana 커스텀 필드 GID ──────────────────────────────────
// Asana 프로젝트 안에서 사용하는 커스텀필드 ID입니다.
// 사람이 읽기 좋은 이름으로 변수에 담아두고, 실제 값은 GID를 넣습니다.
const CF_STATUS           = '1207665965030077';
const CF_STATUS_PROGRESS  = '1207665965030078'; // 상태값: 진행
const CF_TASK_TYPE        = '1213891002087335';
const CF_TASK_TYPE_MD     = '1213891002087339'; // 태스크 종류: MD
const CF_TASK_TYPE_PC     = '1213891002087338'; // 태스크 종류: 포토카드
const CF_TASK_TYPE_UPDATE = '1213891002087337'; // 태스크 종류: 업데이트


// ── 3. 파싱 규칙용 키워드 ─────────────────────────────────────

// 포토카드처럼 보이더라도 실제로는 포토카드가 아니라고 판단할 키워드
// 예: "키링 포토카드" 같은 혼동 문구 방지
const EXCLUDE_KEYWORDS_PC = ['참석권', '관람권', '앨범', '이벤트', '키링', '폴라로이드', '포스트잇'];

// 특전으로 인정할 키워드 목록
// 셀 안에 아래 단어가 있으면 특전 후보로 봅니다.
const BENEFIT_KEYWORDS = [
  '키링', '뱃지', '카드', '엽서', 'L홀더', '우표',
  '인화 2컷', '인화 4컷', '증명사진', '탑로더', '볼펜',
  '골 트래커', '골트래커', '메시지 카드', '스티커', '메모지', '시험지'
];

// 특전 제외 패턴
// 단순히 "앨범"이 들어갔다고 제외하지 않고,
// "한 주문 건에서 ... 구매 시" 같은 '조건 설명 문장'만 제외합니다.
const EXCLUDE_PATTERNS_BENEFIT = [
  /한\s*주문\s*건에서.*구매\s*시/i,
  /중복\s*없이.*세트\s*증정/i,
  /추가\s*증정/i
];

// 이름 안에 아래 단어가 있으면
// Asana 본문의 "손그림/글씨 사용 여부"를 O로 자동 표시합니다.
const HANDWRITING_KEYWORDS = [
  '부적', '상장', '탐정', '메시지', '생일', '프리쿠라',
  '메세지', '낙서', '행운'
];


// ── 4. 시트 메뉴 생성 ─────────────────────────────────────────
// 스프레드시트를 열 때 사용자 메뉴에 버튼을 추가합니다.
function onOpen() {
  SpreadsheetApp.getUi()
    .createMenu('Asana 자동화')
    .addItem('📋 MD + 업데이트 태스크 생성', 'runPhotocardAutomation')
    .addSeparator()
    .addItem('⚙️ 연결 테스트', 'testAsanaConnection')
    .addToUi();
}


// ── 5. 메인 실행 함수 ─────────────────────────────────────────
// 사용자가 메뉴에서 "MD + 업데이트 태스크 생성"을 누르면 이 함수가 시작됩니다.
function runPhotocardAutomation() {
  var ui = SpreadsheetApp.getUi();

  // 1) Asana 토큰이 비어 있으면 실행 중단
  if (!ASANA_TOKEN || ASANA_TOKEN.length < 10) {
    ui.alert('⚠️ 설정 필요', 'ASANA_TOKEN을 입력해주세요.', ui.ButtonSet.OK);
    return;
  }

  // 현재 열려 있는 시트(활성 시트)를 가져옴
  var sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();

  // 2) 상품코드 찾기
  var productCode = getProductCode_(sheet);
  if (!productCode) {
    ui.alert('❌ 상품코드 없음', '시트에서 상품코드를 찾지 못했습니다.', ui.ButtonSet.OK);
    return;
  }

  // 3) 시트에서 포토카드 / 특전 정보 파싱
  var photocards = parsePhotocards_(sheet);
  var benefits   = parseBenefits_(sheet);

  // 둘 다 못 찾았으면 실행 중단
  if (photocards.length === 0 && benefits.length === 0) {
    ui.alert('❌ 데이터 없음', '포토카드와 특전 항목 모두 찾지 못했습니다.', ui.ButtonSet.OK);
    return;
  }

  // 총 종수 계산
  // 예: 포토카드 A 2종 + 포토카드 B 3종 => 총 5종
  var pcTotal = photocards.reduce(function(s, p) { return s + p.count; }, 0);
  var spTotal = benefits.reduce(function(s, b) { return s + b.count; }, 0);

  // 화면 표시용 라벨 (A, B, C ...)
  var LABELS  = ['A','B','C','D','E','F','G','H','I','J'];

  // 포토카드 미리보기 문자열 만들기
  var pcPreview = photocards.length > 0
    ? photocards.map(function(p, i) {
        return '  포토카드 ' + (LABELS[i] || i + 1) + ': ' + p.name + ' (' + p.count + '종)'
          + (hasKeyword_(p.name, HANDWRITING_KEYWORDS) ? ' ✏️' : '');
      }).join('\n')
    : '  (없음)';

  // 특전 미리보기 문자열 만들기
  var spPreview = benefits.length > 0
    ? benefits.map(function(b, i) {
        return '  특전 ' + (LABELS[i] || i + 1) + ': ' + b.name + ' (' + b.count + '종)'
          + (hasKeyword_(b.name, HANDWRITING_KEYWORDS) ? ' ✏️' : '');
      }).join('\n')
    : '  (없음)';

  // 4) 사용자에게 "정말 생성할까요?" 확인창 보여주기
  var confirm = ui.alert(
    '✅ 생성 확인',
    '상품코드: ' + productCode + '\n\n' +
    '① [' + productCode + '] MD\n' +
    '   └ 포토카드 / ' + photocards.length + '세트 ' + pcTotal + '종\n' +
    pcPreview + '\n' +
    '   └ 특전 / ' + benefits.length + '종 총' + spTotal + '종\n' +
    spPreview + '\n\n' +
    '② [' + productCode + '] 업데이트\n' +
    // 업데이트 제목 종수는 포토카드 개수 + 특전 개수
    '   └ [' + productCode + '] 업데이트 / ' + (photocards.length + benefits.length) + '종\n\n' +
    '(✏️ = 손그림/글씨 O 자동 기입)\n\n' +
    'TESTFARM에 생성하시겠습니까?',
    ui.ButtonSet.YES_NO
  );

  // 아니오를 누르면 여기서 종료
  if (confirm !== ui.Button.YES) return;

  // 5) 실제로 Asana에 섹션/태스크 생성
  try {
    var sectionGid = createSection_(TESTFARM_GID, '[' + productCode + ']');

    createMdTasks_(productCode, photocards, pcTotal, benefits, spTotal, sectionGid);
    createUpdateTasks_(productCode, photocards, benefits, sectionGid);

    ui.alert(
      '🎉 생성 완료',
      '[' + productCode + '] 섹션과 태스크가 생성됐습니다.\n' +
      'https://app.asana.com/0/' + TESTFARM_GID,
      ui.ButtonSet.OK
    );
  } catch (e) {
    // 에러 발생 시 사용자에게 메시지 띄우고 로그 남김
    ui.alert('❌ 오류 발생', e.message, ui.ButtonSet.OK);
    Logger.log(e.stack);
  }
}


// ══════════════════════════════════════════════════════════════
//  6. MD 태스크 생성
// ══════════════════════════════════════════════════════════════
function createMdTasks_(productCode, photocards, pcTotal, benefits, spTotal, sectionGid) {
  // 마감일 계산
  var dueDate    = getDueDate_(DUE_DAYS_OFFSET);

  // 태스크 이름 만들기
  var mdName     = '[' + productCode + '] MD';
  var pcTaskName = '[' + productCode + '] 포토카드 / ' + photocards.length + '세트 ' + pcTotal + '종';
  var spTaskName = '[' + productCode + '] 특전 / ' + benefits.length + '종 총' + spTotal + '종';

  // 상위 MD 태스크에 넣을 커스텀 필드 값
  var cfMd = {};
  cfMd[CF_STATUS]    = CF_STATUS_PROGRESS;
  cfMd[CF_TASK_TYPE] = CF_TASK_TYPE_MD;

  // 1) 상위 MD 태스크 생성
  var mdGid = createTask_({
    name:          mdName,
    projects:      [TESTFARM_GID],
    assignee:      ASSIGNEE_GID,
    due_on:        dueDate,
    notes:         '발주 후 "완료" 처리 부탁드립니다!',
    followers:     [ASSIGNEE_GID],
    custom_fields: cfMd
  });

  // 만든 상위 MD 태스크를 상품 섹션에 넣음
  addTaskToSection_(mdGid, sectionGid);
  Logger.log('MD: ' + mdGid);

  // 2) 포토카드가 있으면 하위 포토카드 태스크 생성
  if (photocards.length > 0) {
    var cfPc = {};
    cfPc[CF_TASK_TYPE] = CF_TASK_TYPE_PC;

    createTask_({
      name:          pcTaskName,
      parent:        mdGid, // 상위 MD 태스크 아래에 달기
      assignee:      ASSIGNEE_GID,
      due_on:        dueDate,
      html_notes:    buildPhotocardDescription_(photocards),
      followers:     [ASSIGNEE_GID],
      custom_fields: cfPc
    });

    Logger.log('포토카드: ' + pcTaskName);
  }

  // 3) 특전 하위 태스크 생성
  // 현재 구조상 benefits.length가 0이어도 태스크는 생성됩니다.
  // 필요하면 나중에 if (benefits.length > 0) 조건으로 감쌀 수 있습니다.
  var cfSp = {};
  cfSp[CF_TASK_TYPE] = CF_TASK_TYPE_MD;

  createTask_({
    name:          spTaskName,
    parent:        mdGid,
    assignee:      ASSIGNEE_GID,
    due_on:        dueDate,
    html_notes:    buildBenefitDescription_(benefits),
    followers:     [ASSIGNEE_GID],
    custom_fields: cfSp
  });

  Logger.log('특전: ' + spTaskName);
}


// ══════════════════════════════════════════════════════════════
//  7. 업데이트 태스크 생성
// ══════════════════════════════════════════════════════════════
function createUpdateTasks_(productCode, photocards, benefits, sectionGid) {
  var dueDate     = getDueDate_(DUE_DAYS_OFFSET);

  // 업데이트 제목에 표시할 "전체 산출물 개수"
  // 포토카드 개수 + 특전 개수
  var outputCount = photocards.length + benefits.length;

  // 상위 업데이트 태스크 이름
  var upName    = '[' + productCode + '] 업데이트';

  // 하위 업데이트 태스크 이름
  var upSubName = '[' + productCode + '] 업데이트 / ' + outputCount + '종';

  // 상위 업데이트 태스크 커스텀필드
  var cfUp = {};
  cfUp[CF_STATUS]    = CF_STATUS_PROGRESS;
  cfUp[CF_TASK_TYPE] = CF_TASK_TYPE_UPDATE;

  // 1) 상위 업데이트 태스크 생성
  var upGid = createTask_({
    name:          upName,
    projects:      [TESTFARM_GID],
    assignee:      ASSIGNEE_GID,
    due_on:        dueDate,
    notes:         'SNS 발행 후 "완료" 처리 부탁드립니다!',
    followers:     [ASSIGNEE_GID],
    custom_fields: cfUp
  });

  // 상품 섹션에 넣기
  addTaskToSection_(upGid, sectionGid);
  Logger.log('업데이트 상위: ' + upGid);

  // 2) 하위 업데이트 태스크 생성
  var cfUpSub = {};
  cfUpSub[CF_TASK_TYPE] = CF_TASK_TYPE_UPDATE;

  createTask_({
    name:          upSubName,
    parent:        upGid,
    assignee:      ASSIGNEE_GID,
    due_on:        dueDate,
    html_notes:    buildUpdateDescription_(photocards, benefits),
    followers:     [ASSIGNEE_GID],
    custom_fields: cfUpSub
  });

  Logger.log('업데이트 하위: ' + upSubName);
}


// ══════════════════════════════════════════════════════════════
//  8. Asana 본문(설명) HTML 만들기
// ══════════════════════════════════════════════════════════════
// Asana는 html_notes를 받기 때문에 HTML 문자열을 만들어서 넘깁니다.

function buildPhotocardDescription_(photocards) {
  var LABELS = ['A','B','C','D','E','F','G','H','I','J'];

  // 본문 시작
  var html = '<body><em>*더 필요한 산출물은 추가, 사용하지 않는 산출물은 삭제해주세요!</em>';

  for (var i = 0; i < photocards.length; i++) {
    var pc      = photocards[i];
    var label   = LABELS[i] || String(i + 1);

    // 이름에 손그림/글씨 키워드가 있으면 O, 아니면 X
    var hwValue = hasKeyword_(pc.name, HANDWRITING_KEYWORDS) ? 'O' : 'X';

    html += '\n\n<strong>포토카드 ' + label + ': ' + pc.name + ' (' + pc.count + '종)</strong>';
    html += '<ol>';
    html += '<li>스펙<ol type="a"><li>(55*85가 아닐 경우, 주문 상세 페이지 URL 또는 스펙 공유)</li></ol></li>';
    html += '<li>문의<ol type="a"><li>손그림, 글씨 사용 여부 : ' + hwValue + '</li></ol></li>';
    html += '<li>자료<ol type="a"><li>URL 또는 MAS 위치</li></ol></li>';
    html += '<li>공유, 요청<ol type="a"><li>소속사 요청 사항, 디자인 컨셉, 아이디어 등 공유가 필요한 내용을 편하게 남겨주세요!</li></ol></li>';
    html += '</ol>';
  }

  html += '</body>';
  return html;
}


function buildBenefitDescription_(benefits) {
  var LABELS = ['A','B','C','D','E','F','G','H','I','J'];
  var html   = '<body><em>*더 필요한 산출물은 추가, 사용하지 않는 산출물은 삭제해주세요!</em>';

  for (var i = 0; i < benefits.length; i++) {
    var b       = benefits[i];
    var label   = LABELS[i] || String(i + 1);
    var hwValue = hasKeyword_(b.name, HANDWRITING_KEYWORDS) ? 'O' : 'X';

    html += '\n\n<strong>특전 ' + label + ': ' + b.name + ' (' + b.count + '종)</strong>';
    html += '<ol>';
    html += '<li>스펙<ol type="a">';
    html += '<li>주문 상세 페이지 URL</li>';
    html += '<li>(또는 상품 스펙)</li>';
    html += '</ol></li>';
    html += '<li>문의<ol type="a"><li>손그림, 글씨 사용 여부 : ' + hwValue + '</li></ol></li>';
    html += '<li>자료<ol type="a"><li>URL 또는 MAS 위치</li></ol></li>';
    html += '<li>공유, 요청<ol type="a"><li>소속사 요청 사항, 디자인 컨셉, 아이디어 등 공유가 필요한 내용을 편하게 남겨주세요!</li></ol></li>';
    html += '</ol>';
  }

  html += '</body>';
  return html;
}


function buildUpdateDescription_(photocards, benefits) {
  var LABELS = ['A','B','C','D','E','F','G','H','I','J'];
  var html = '<body>';

  // 업데이트 태스크의 기본 고정 문구
  html += '<strong>자료</strong>';
  html += '<ol><li>URL 또는 MAS 위치</li></ol>';

  html += '\n\n<strong>문의</strong>';
  html += '<ol>';
  html += '<li>블러 강도 <strong>(3)</strong>단계</li>';
  html += '<li>(자료 수급 일정)</li>';
  html += '</ol>';

  html += '\n\n<strong>공유, 요청</strong>';
  html += '<ol><li>소속사 요청 사항, 디자인 컨셉, 아이디어 등 공유가 필요한 내용을 편하게 남겨주세요!</li></ol>';

  // 필요한 산출물 목록을 담을 배열
  var outputItems = [];

  // 포토카드 목록 추가
  for (var i = 0; i < photocards.length; i++) {
    var pcLabel = LABELS[i] || String(i + 1);
    outputItems.push('<li>포카 ' + pcLabel + ' 버전 : ' + photocards[i].name + ' (' + photocards[i].count + '종)</li>');
  }

  // 특전 목록 추가
  for (var j = 0; j < benefits.length; j++) {
    var spLabel = LABELS[j] || String(j + 1);
    outputItems.push('<li>특전 ' + spLabel + ' 버전 : ' + benefits[j].name + ' (' + benefits[j].count + '종)</li>');
  }

  // 산출물이 하나라도 있으면 "필요한 산출물" 섹션 생성
  if (outputItems.length > 0) {
    html += '\n\n<strong>필요한 산출물</strong>';
    html += '<ol>' + outputItems.join('') + '</ol>';
    html += '\n\n<em>*더 필요한 산출물은 추가, 사용하지 않는 산출물은 삭제해주세요!</em>';
  }

  html += '</body>';
  return html;
}


// ══════════════════════════════════════════════════════════════
//  9. 시트 파싱 함수들
// ══════════════════════════════════════════════════════════════

// 상품코드 찾기
// 방법 1) 셀 값이 정확히 '상품코드'이면 오른쪽 셀 값을 사용
// 방법 2) P_12345 같은 패턴이 있으면 그것을 상품코드로 사용
function getProductCode_(sheet) {
  var data = sheet.getDataRange().getValues();

  for (var i = 0; i < data.length; i++) {
    for (var j = 0; j < data[i].length; j++) {
      var cell = String(data[i][j]).trim();

      if (cell === '상품코드' && j + 1 < data[i].length) {
        var code = String(data[i][j + 1]).trim();
        if (code) return code;
      }

      var m = cell.match(/^(P_\d+[A-Z0-9_]*)$/i);
      if (m) return m[1];
    }
  }

  return null;
}


// 포토카드 목록 읽기
function parsePhotocards_(sheet) {
  var data = sheet.getDataRange().getValues();

  // results: 최종 결과 배열
  // seen: 이미 넣은 이름인지 체크하는 객체
  // inSection: '메이크스타 특전' 영역에 들어왔는지 여부
  var results = [], seen = {}, inSection = false;

  for (var i = 0; i < data.length; i++) {
    // 한 행 전체를 합쳤을 때 '메이크스타 특전'이 있으면 그 아래부터 읽기 시작
    if (data[i].join(' ').indexOf('메이크스타 특전') !== -1) inSection = true;
    if (!inSection) continue;

    for (var j = 0; j < data[i].length; j++) {
      var cell = String(data[i][j]).trim();

      // 비어 있거나, '포토카드'가 없으면 건너뜀
      if (!cell || cell.indexOf('포토카드') === -1) continue;

      // 제외 키워드가 하나라도 있으면 포토카드로 보지 않음
      var excluded = false;
      for (var k = 0; k < EXCLUDE_KEYWORDS_PC.length; k++) {
        if (cell.indexOf(EXCLUDE_KEYWORDS_PC[k]) !== -1) {
          excluded = true;
          break;
        }
      }
      if (excluded) continue;

      // 수량 찾기 (예: 2종, 3매)
      var cm = cell.match(/(\d+)\s*(?:매|종)/);
      if (!cm) continue;
      var count = parseInt(cm[1], 10);

      // 이름 정리
      // 예:
      // '1. 셀카 포토카드 2종 (랜덤)' -> '셀카 포토카드'
      var name = cell
        .replace(/^\d+\.\s*/, '')
        .replace(/^[-•]\s*/, '')
        .replace(/\s*\d+\s*(?:매|종).*$/, '')
        .replace(/\s*\(.*?\)/g, '')
        .replace(/\s*-.*$/, '')
        .trim();

      // 이름이 너무 짧거나 이미 같은 이름을 넣었다면 제외
      if (!name || name.length < 3 || seen[name]) continue;

      seen[name] = true;
      results.push({ name: name, count: count });
    }
  }

  return results;
}


// 특전 목록 읽기
function parseBenefits_(sheet) {
  var data = sheet.getDataRange().getValues();
  var results = [], seen = {}, inSection = false;

  for (var i = 0; i < data.length; i++) {
    if (data[i].join(' ').indexOf('메이크스타 특전') !== -1) inSection = true;
    if (!inSection) continue;

    for (var j = 0; j < data[i].length; j++) {
      var cell = String(data[i][j]).trim();
      if (!cell) continue;

      // 특전 키워드가 있나 확인
      var benefitKeyword = findBenefitKeyword_(cell);
      if (!benefitKeyword) continue;

      // 포토카드는 여기서 처리하지 않음
      if (cell.indexOf('포토카드') !== -1) continue;

      // 셀 안에서 "실제 특전명 + 수량" 뽑아내기
      // 예: '한 주문 건에서 앨범 1매 이상 구매 시 키링 1종 증정'
      // -> { name: '키링', count: 1 }
      var benefitItem = extractBenefitItem_(cell, benefitKeyword);
      if (!benefitItem) continue;

      // 조건 설명 문장만 있는 경우는 제외
      // 다만 실제 특전명 + 수량이 뚜렷하면 살려줌
      if (shouldExcludeBenefitCell_(cell, benefitItem.name, benefitItem.count)) continue;

      // 같은 이름이 이미 있으면 count를 누적
      if (seen[benefitItem.name] !== undefined) {
        results[seen[benefitItem.name]].count += benefitItem.count;
      } else {
        seen[benefitItem.name] = results.length;
        results.push({ name: benefitItem.name, count: benefitItem.count });
      }
    }
  }

  return results;
}


// 특전 셀을 제외해야 하는지 판단
function shouldExcludeBenefitCell_(cell, benefitName, count) {
  var normalized = String(cell).replace(/\s+/g, ' ').trim();

  // 실제 특전명 + 수량이 들어 있으면 제외하지 않음
  // 예: '키링 1종'
  var concreteBenefitPattern = new RegExp(escapeRegExp_(benefitName) + '\\s*' + count + '\\s*(?:매|종|개)');
  if (concreteBenefitPattern.test(normalized)) return false;

  // 위 조건이 아니라면, 제외 패턴에 걸리는지 확인
  for (var i = 0; i < EXCLUDE_PATTERNS_BENEFIT.length; i++) {
    if (EXCLUDE_PATTERNS_BENEFIT[i].test(normalized)) return true;
  }

  return false;
}


// 셀 문자열 안에서 실제 특전 아이템을 뽑아냄
function extractBenefitItem_(cell, benefitKeyword) {
  var normalized = String(cell).replace(/\s+/g, ' ').trim();
  var escapedKeyword = escapeRegExp_(benefitKeyword);

  // benefitKeyword 뒤에 수량이 붙은 형태 찾기
  // 예: '아크릴 키링 1종' -> name 후보는 '아크릴 키링', count는 1
  var match = normalized.match(new RegExp('(.{0,80}?' + escapedKeyword + ')\\s*(\\d+)\\s*(?:매|종|개)'));
  if (!match) return null;

  var name = match[1]
    .replace(/^\d+\.\s*/, '')
    .replace(/^[-•]\s*/, '')
    .replace(/.*(?:구매\s*시|특전\s*[:：]|증정품\s*[:：]|구성\s*[:：]|\/|,|·)\s*/, '')
    .replace(/\s*\(.*?\)\s*$/g, '')
    .trim();

  if (!name || name.length < 2) return null;

  return {
    name: name,
    count: parseInt(match[2], 10)
  };
}


// 정규식 특수문자 이스케이프
// 예: 괄호, 점 같은 문자가 정규식에서 오작동하지 않게 처리
function escapeRegExp_(text) {
  return String(text).replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
}


// 텍스트 안에 특전 키워드가 있는지 찾기
// 있으면 해당 키워드를 반환, 없으면 null 반환
function findBenefitKeyword_(text) {
  for (var i = 0; i < BENEFIT_KEYWORDS.length; i++) {
    if (text.indexOf(BENEFIT_KEYWORDS[i]) !== -1) return BENEFIT_KEYWORDS[i];
  }
  return null;
}


// 텍스트 안에 특정 키워드 배열 중 하나라도 들어 있는지 확인
// true / false 반환
function hasKeyword_(text, keywords) {
  for (var i = 0; i < keywords.length; i++) {
    if (text.indexOf(keywords[i]) !== -1) return true;
  }
  return false;
}


// ══════════════════════════════════════════════════════════════
//  10. Asana API 호출용 헬퍼 함수
// ══════════════════════════════════════════════════════════════

// Asana API를 공통 방식으로 호출하는 함수
function asanaRequest_(method, endpoint, payload) {
  var options = {
    method: method,
    headers: {
      'Authorization': 'Bearer ' + ASANA_TOKEN,
      'Content-Type':  'application/json',
      'Accept':        'application/json'
    },
    muteHttpExceptions: true
  };

  // GET / DELETE가 아니면 payload를 JSON으로 담아서 전송
  if (payload !== null && method !== 'get' && method !== 'delete') {
    options.payload = JSON.stringify({ data: payload });
  }

  var response = UrlFetchApp.fetch('https://app.asana.com/api/1.0' + endpoint, options);
  var code     = response.getResponseCode();

  // 204는 내용 없는 정상 응답
  if (code === 204) return null;

  var body = JSON.parse(response.getContentText());

  // 200번대가 아니면 에러로 처리
  if (code < 200 || code >= 300) {
    var msg = (body.errors && body.errors[0]) ? body.errors[0].message : JSON.stringify(body);
    throw new Error('Asana API 오류 (' + code + '): ' + msg);
  }

  return body.data;
}


// 태스크 생성 후 gid 반환
function createTask_(payload) {
  return asanaRequest_('post', '/tasks', payload).gid;
}


// 프로젝트 안에 섹션 생성 후 gid 반환
function createSection_(projectGid, name) {
  return asanaRequest_('post', '/projects/' + projectGid + '/sections', { name: name }).gid;
}


// 태스크를 특정 섹션에 넣기
function addTaskToSection_(taskGid, sectionGid) {
  asanaRequest_('post', '/sections/' + sectionGid + '/addTask', { task: taskGid });
}


// 오늘 기준 n일 뒤 날짜를 YYYY-MM-DD 형식으로 반환
function getDueDate_(days) {
  var d = new Date();
  d.setDate(d.getDate() + days);

  return d.getFullYear() + '-' +
    String(d.getMonth() + 1).padStart(2, '0') + '-' +
    String(d.getDate()).padStart(2, '0');
}


// Asana 연결 테스트용 함수
// 현재 토큰으로 /users/me 호출해서 로그인 사용자 정보가 뜨는지 확인
function testAsanaConnection() {
  var ui = SpreadsheetApp.getUi();

  try {
    var me = asanaRequest_('get', '/users/me', null);
    ui.alert('✅ 연결 성공', '인증된 사용자: ' + me.name + '\n(' + me.email + ')', ui.ButtonSet.OK);
  } catch (e) {
    ui.alert('❌ 연결 실패', e.message, ui.ButtonSet.OK);
  }
}
